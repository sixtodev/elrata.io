# =============================================
# SUPABASE
# =============================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# =============================================
# AI PROVIDERS — Round-Robin (configura al menos uno)
# =============================================
OPEN_ROUTE_API_KEY=sk-or-v1-...
CEREBRAS_API_KEY=csk-...
GROQ_API_KEY=gsk_...

# =============================================
# WEB SEARCH — Cadena de fallback (configura al menos uno)
# =============================================

# Serper.dev — 2,500 búsquedas gratis (RECOMENDADO)
# https://serper.dev
SERPER_API_KEY=your-serper-key

# SerpAPI — 100 búsquedas/mes gratis
# https://serpapi.com
SERPAPI_API_KEY=your-serpapi-key

# Google Custom Search — 100 búsquedas/día gratis
# https://programmablesearchengine.google.com/
GOOGLE_CSE_API_KEY=your-google-cse-key
GOOGLE_CSE_CX=your-search-engine-id

# =============================================
# MERCADOLIBRE API
# https://developers.mercadolibre.com.ar/devcenter
# =============================================
ML_CLIENT_ID=
ML_CLIENT_SECRET=
ML_ACCESS_TOKEN=
ML_REFRESH_TOKEN=

# =============================================
# EMAIL — Resend
# =============================================
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=alertas@yourdomain.com

# =============================================
# CRON — Seguridad
# =============================================
CRON_SECRET=generate-a-random-secret-here

# =============================================
# APP
# =============================================
NEXT_PUBLIC_APP_URL=https://yourdomain.com
